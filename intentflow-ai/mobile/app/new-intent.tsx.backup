    flexDirection: 'row',
    flexWrap: 'wrap',
    gap: 8,
  },
  quickSuggestionChip: {
    backgroundColor: COLORS.bgCard,
    borderWidth: 1,
    borderColor: COLORS.borderSubtle,
    paddingHorizontal: 14,
    paddingVertical: 8,
    borderRadius: 10,
  },
  quickSuggestionText: {
    color: COLORS.textSecondary,
    fontSize: 13,
  },

  // Structured Section
  structuredSection: {
    paddingHorizontal: 20,
    marginBottom: 24,
  },
  sectionTitle: {
    fontSize: 13,
    fontWeight: '600',
    color: COLORS.textSecondary,
    marginBottom: 16,
  },

  // Chips Container
  chipsContainer: {
    flexDirection: 'row',
    flexWrap: 'wrap',
    gap: 10,
    marginBottom: 20,
  },
  entityPill: {
    flexDirection: 'row',
    alignItems: 'center',
    gap: 8,
    backgroundColor: COLORS.bgCard,
    borderWidth: 1,
    borderColor: COLORS.borderSubtle,
    paddingHorizontal: 14,
    paddingVertical: 10,
    borderRadius: 24,
  },
  entityPillPrimary: {
    backgroundColor: 'rgba(124, 58, 237, 0.15)',
    borderColor: COLORS.accentPrimary,
  },
  entityPillText: {
    color: COLORS.textPrimary,
    fontSize: 14,
    fontWeight: '500',
  },
  entityPillTextPrimary: {
    color: COLORS.accentSecondary,
  },

  // AI Suggestions Panel
  aiSuggestionsPanel: {
    backgroundColor: 'rgba(124, 58, 237, 0.08)',
    borderWidth: 1,
    borderColor: 'rgba(124, 58, 237, 0.3)',
    borderRadius: 16,
    padding: 16,
    marginBottom: 20,
  },
  aiSuggestionsHeader: {
    flexDirection: 'row',
    alignItems: 'center',
    gap: 8,
    marginBottom: 12,
  },
  aiSuggestionsTitle: {
    fontSize: 13,
    fontWeight: '600',
    color: COLORS.accentSecondary,
    textTransform: 'uppercase',
    letterSpacing: 0.5,
  },
  aiSuggestionItem: {
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'space-between',
    paddingVertical: 12,
    borderBottomWidth: 1,
    borderBottomColor: COLORS.borderSubtle,
  },
  aiSuggestionText: {
    fontSize: 14,
    color: COLORS.textSecondary,
    flex: 1,
  },
  aiSuggestionBtn: {
    backgroundColor: COLORS.bgCard,
    borderWidth: 1,
    borderColor: COLORS.borderSubtle,
    paddingHorizontal: 12,
    paddingVertical: 6,
    borderRadius: 8,
    marginLeft: 12,
  },
  aiSuggestionBtnText: {
    color: COLORS.textSecondary,
    fontSize: 12,
    fontWeight: '500',
  },

  // Parameters Grid
  paramsGrid: {
    flexDirection: 'row',
    flexWrap: 'wrap',
    gap: 12,
  },
  paramCard: {
    width: (SCREEN_WIDTH - 52) / 2,
    backgroundColor: COLORS.bgCard,
    borderWidth: 1,
    borderColor: COLORS.borderSubtle,
    borderRadius: 14,
    padding: 14,
  },
  paramLabel: {
    fontSize: 10,
    fontWeight: '600',
    textTransform: 'uppercase',
    letterSpacing: 0.6,
    color: COLORS.textMuted,
    marginBottom: 8,
  },
  paramValue: {
    flexDirection: 'row',
    alignItems: 'center',
    gap: 8,
  },
  paramValueText: {
    fontSize: 14,
    fontWeight: '500',
    color: COLORS.textPrimary,
    flex: 1,
  },

  // Processing
  processingContainer: {
    alignItems: 'center',
    paddingVertical: 40,
  },
  processingText: {
    marginTop: 12,
    color: COLORS.textSecondary,
    fontSize: 14,
  },

  // Footer
  footer: {
    position: 'absolute',
    bottom: 0,
    left: 0,
    right: 0,
    paddingHorizontal: 20,
    paddingTop: 10,
    flexDirection: 'row',
    gap: 12,
    backgroundColor: 'transparent',
  },
  dictateBtn: {
    flex: 1,
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'center',
    gap: 10,
    backgroundColor: COLORS.bgCard,
    borderWidth: 1,
    borderColor: COLORS.borderSubtle,
    paddingVertical: 14,
    paddingHorizontal: 20,
    borderRadius: 14,
  },
  dictateBtnRecording: {
    backgroundColor: 'rgba(239, 68, 68, 0.15)',
    borderColor: '#ef4444',
  },
  dictateText: {
    color: COLORS.textSecondary,
    fontSize: 15,
    fontWeight: '500',
  },
  dictateTextRecording: {
    color: '#ef4444',
  },
  magicBtn: {
    width: 52,
    height: 52,
    backgroundColor: COLORS.accentPrimary,
    borderRadius: 14,
    alignItems: 'center',
    justifyContent: 'center',
    shadowColor: COLORS.accentPrimary,
    shadowOffset: { width: 0, height: 4 },
    shadowOpacity: 0.3,
    shadowRadius: 12,
    elevation: 8,
  },

  // Toast
  toast: {
    position: 'absolute',
    top: 80,
    left: '50%',
    transform: [{ translateX: -100 }],
    backgroundColor: COLORS.bgCard,
    borderWidth: 1,
    borderColor: COLORS.borderSubtle,
    paddingHorizontal: 20,
    paddingVertical: 12,
    borderRadius: 12,
    zIndex: 1000,
    width: 200,
    alignItems: 'center',
  },
  toastText: {
    color: COLORS.textPrimary,
    fontSize: 14,
  },
});
